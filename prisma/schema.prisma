// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  password            String    // bcrypt hash
  name                String?
  organization        String?
  role                String?   // e.g. "ADAS Validation Engineer"
  bio                 String?
  // preferences stored as JSON — no separate table needed for MVP
  preferences         Json?     // { theme, compactMode, language, timezone }
  notifications       Json?     // { pipelineDone, gateRequired, stageFailed, weeklyDigest, slackWebhookUrl }
  resetToken          String?   // hashed reset token
  resetTokenExpires   DateTime? // token expiration time
  createdAt           DateTime  @default(now())
  projects            Project[]
}

model Project {
  id            String         @id @default(cuid())
  name          String
  description   String?
  userId        String
  user          User           @relation(fields: [userId], references: [id])
  conversations Conversation[]
  createdAt     DateTime       @default(now())
}

model Conversation {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  pipeline  Json?    // Full ConversationPipeline state as JSONB — no normalization needed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
